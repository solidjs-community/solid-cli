{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"declaration": true,
		"emitDeclarationOnly": true,
		"rootDir": "./src",
		"outDir": "types"
	},
	"include": ["src/*"]
}
